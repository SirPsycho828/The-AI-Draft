    "rss-parser": "^3.13.0",
    "apify-client": "^2.9.0"
  },
  "devDependencies": {
    "@types/node-fetch": "^2.6.12",
    "typescript": "^5.7.0"
  },
  "private": true,
  "overrides": {
    "uuid": ">=11.1.1"
  }
